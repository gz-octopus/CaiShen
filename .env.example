# ============================================================
# 环境变量模板 — 复制为 .env 并填入真实值
# .env 文件已被 .gitignore 忽略，不会提交到版本控制
# ============================================================

# PostgreSQL 数据库密码（本地开发默认: postgres_pwd）
PG_PASSWORD=postgres_pwd

# Tushare API token（从 https://tushare.pro 获取）
TUSHARE_TOKEN=your_tushare_token_here

# Firecrawler API key
FIRECRAWLER_API_KEY=your_firecrawler_api_key_here
